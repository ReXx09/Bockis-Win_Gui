# Funktion zum Anzeigen des Abhängigkeits-Managements in der GUI
function Show-DependencyManager {
    param (
        [System.Windows.Forms.RichTextBox]$OutputBox,
        [System.Windows.Forms.Form]$MainForm
    )
    
    # Erstelle ein neues Formular
    $form = New-Object System.Windows.Forms.Form
    $form.Text = "Abhängigkeiten-Manager"
    $form.Size = New-Object System.Drawing.Size(600, 400)
    $form.StartPosition = "CenterParent"
    $form.FormBorderStyle = [System.Windows.Forms.FormBorderStyle]::FixedDialog
    $form.MaximizeBox = $false
    $form.MinimizeBox = $false
    
    # Erstelle eine RichTextBox für die Ausgabe
    $rtbDependencies = New-Object System.Windows.Forms.RichTextBox
    $rtbDependencies.Location = New-Object System.Drawing.Point(10, 10)
    $rtbDependencies.Size = New-Object System.Drawing.Size(570, 280)
    $rtbDependencies.ReadOnly = $true
    $rtbDependencies.BackColor = [System.Drawing.Color]::White
    $rtbDependencies.Font = New-Object System.Drawing.Font("Consolas", 10)
    $form.Controls.Add($rtbDependencies)
    
    # Erstelle Buttons für die Aktionen
    $btnCheck = New-Object System.Windows.Forms.Button
    $btnCheck.Location = New-Object System.Drawing.Point(10, 300)
    $btnCheck.Size = New-Object System.Drawing.Size(150, 40)
    $btnCheck.Text = "Abhängigkeiten prüfen"
    $btnCheck.Add_Click({
            $rtbDependencies.Clear()
            Test-Dependencies -OutputBox $rtbDependencies -Verbose
        })
    $form.Controls.Add($btnCheck)
    
    $btnInstall = New-Object System.Windows.Forms.Button
    $btnInstall.Location = New-Object System.Drawing.Point(170, 300)
    $btnInstall.Size = New-Object System.Drawing.Size(150, 40)
    $btnInstall.Text = "Alle installieren"
    $btnInstall.Add_Click({
            $rtbDependencies.Clear()
            Install-Dependencies -OutputBox $rtbDependencies
        })
    $form.Controls.Add($btnInstall)
    
    $btnClose = New-Object System.Windows.Forms.Button
    $btnClose.Location = New-Object System.Drawing.Point(430, 300)
    $btnClose.Size = New-Object System.Drawing.Size(150, 40)
    $btnClose.Text = "Schliessen"
    $btnClose.Add_Click({ $form.Close() })
    $form.Controls.Add($btnClose)
    
    # Initial scan ausführen
    Test-Dependencies -OutputBox $rtbDependencies -Verbose
    
    # Formular anzeigen
    if ($MainForm -ne $null) {
        $form.Owner = $MainForm
    }
    $form.ShowDialog() | Out-Null
}

# Exportiere die öffentlichen Funktionen
Export-ModuleMember -Function Test-Dependencies, Install-Dependencies, Show-DependencyManager 