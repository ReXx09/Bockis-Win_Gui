# ToolLibrary.psm1 - Bibliothek für Tool-Downloads
# Autor: Bocki

# Benötigte Assemblies laden
Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

# Tool-Definitionen als Hash-Tabelle
