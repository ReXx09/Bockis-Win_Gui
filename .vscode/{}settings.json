{
    // PowerShell-Einstellungen für Bockis-Win_Gui Projekt
    "powershell.scriptAnalysis.enable": true,
    "powershell.integratedConsole.showOnStartup": true,
    "powershell.developer.editorServicesLogLevel": "Warning",
    "powershell.codeFormatting.formatOnPaste": true,
    "powershell.codeFormatting.autoCorrectAliases": true,
    "powershell.enableProfileLoading": true,
    "powershell.codeFormatting.preset": "OTBS",
    "powershell.codeFormatting.openBraceOnSameLine": true,
    "powershell.codeFormatting.newLineAfterOpenBrace": true,
    "powershell.codeFormatting.newLineAfterCloseBrace": true,
    "powershell.codeFormatting.pipelineIndentationStyle": "IncreaseIndentationAfterEveryPipeline",
    "powershell.codeFormatting.whitespaceBeforeOpenBrace": true,
    "powershell.codeFormatting.whitespaceAroundOperator": true,
    "powershell.codeFormatting.alignPropertyValuePairs": true,
    "powershell.codeFormatting.addWhitespaceAroundPipe": true,
    "powershell.scriptAnalysis.settingsPath": "",
    "powershell.buttons.showRunButtons": true,
    "powershell.buttons.showPanelMovementButtons": true,
    "powershell.integratedConsole.focusConsoleOnExecute": false,
    // Dateierkennung für PowerShell GUI-Projekt
    "files.associations": {
        "*.ps1": "powershell",
        "*.psm1": "powershell",
        "*.psd1": "powershell",
        "*.json": "jsonc",
        "*.config": "xml",
        "*.log": "log",
        "*.md": "markdown",
        "*.dll": "binary",
        "*.sys": "binary",
        "*.db": "sql"
    },
    // Explorer-Optimierungen speziell für Bockis-Win_Gui
    "explorer.sortOrder": "type",
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "Win_Gui_Module.ps1": "config.json, *.log, *.db, README.md",
        "*.psm1": "${capture}.psd1, ${capture}_tests.ps1, ${capture}.md",
        "DatabaseManager.psm1": "*.db, *.sql, SQLite*.cs",
        "ToolLibrary.psm1": "tools.json, downloads.json",
        "HardwareMonitorTools.psm1": "*.dll, *.sys",
        "Settings.psm1": "config.json, settings.ini",
        "LogManager.psm1": "*.log, logs.txt"
    },
    // Performance-Optimierungen für Ihr großes Projekt
    "files.watcherExclude": {
        "**/Logs/**": true,
        "**/*.log": true,
        "**/*.db": true,
        "**/temp/**": true,
        "**/cache/**": true,
        "**/Lib/*.dll": true,
        "**/Lib/*.sys": true,
        "**/Downloads/**": true
    },
    // Search-Optimierungen für PowerShell-Projekt
    "search.exclude": {
        "**/Logs": true,
        "**/*.log": true,
        "**/*.db": true,
        "**/temp": true,
        "**/cache": true,
        "**/Lib/*.dll": true,
        "**/Lib/*.sys": true,
        "**/Downloads": true
    },
    // Editor-Einstellungen für PowerShell GUI-Code
    "editor.formatOnSave": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.inlayHints.enabled": "on",
    "editor.wordWrap": "on",
    "editor.rulers": [
        80,
        120
    ],
    "editor.suggestSelection": "first",
    "editor.acceptSuggestionOnCommitCharacter": true,
    "editor.acceptSuggestionOnEnter": "on",
    "editor.tabCompletion": "on",
    "editor.quickSuggestions": {
        "other": "on",
        "comments": "off",
        "strings": "on"
    },
    "editor.minimap.enabled": true,
    // Code-Navigation für große PowerShell-Projekte
    "breadcrumbs.enabled": true,
    "breadcrumbs.showModules": true,
    "breadcrumbs.showFunctions": true,
    "breadcrumbs.showVariables": false,
    "outline.showVariables": false,
    "outline.showFunctions": true,
    // Encoding für PowerShell-Dateien
    "files.encoding": "utf8bom",
    "files.autoGuessEncoding": true,
    "files.candidateGuessEncodings": [
        "utf8"
    ],
    // Terminal-Einstellungen
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.fontFamily": "Consolas",
    "terminal.integrated.fontSize": 14,
    // Debugging-Optimierungen für GUI-Anwendungen
    "debug.console.fontSize": 14,
    "debug.console.fontFamily": "Consolas",
    "debug.allowBreakpointsEverywhere": true,
    "debug.showInlineBreakpointCandidates": true,
    "debug.focusWindowOnBreak": true,
    "debug.openExplorerOnEnd": true,
    // Workspace-spezifische Einstellungen
    "workbench.editor.enablePreview": false,
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "workbench.startupEditor": "newUntitledFile",
    // Git-Einstellungen für das Projekt
    "git.autofetch": true,
    "git.enableSmartCommit": true,
    "git.confirmSync": false
}